# NexusOrbital认证系统环境变量
# 将此文件复制为.env并根据需要修改值

# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
JWT_SECRET=nexusorbital-secure-auth-token-2025
TOKEN_EXPIRY=24h

# 短信服务配置
SMS_API_KEY=your_sms_api_key

# 社交登录配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

WEIBO_APP_KEY=your_weibo_app_key
WEIBO_APP_SECRET=your_weibo_app_secret

XIAOHONGSHU_CLIENT_ID=your_xiaohongshu_client_id
XIAOHONGSHU_CLIENT_SECRET=your_xiaohongshu_client_secret

# 数据库配置（未来版本）
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=nexusorbital
# DB_USER=dbuser
# DB_PASSWORD=dbpassword

# 日志配置
LOG_LEVEL=info

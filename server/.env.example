# NexusOrbital 服务器环境变量示例文件
# 复制此文件为 .env 并填入你的实际配置值

# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
JWT_SECRET=your-jwt-secret-key-here
TOKEN_EXPIRY=24h

# 阿里云短信服务配置
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=NexusOrbital
ALIYUN_SMS_TEMPLATE_CODE=SMS_1234567890

# 邮件服务配置
# 选择邮件提供商: 'smtp' 或 'sendgrid'
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@nexusorbital.com

# SendGrid配置
SENDGRID_API_KEY=your-sendgrid-api-key

# SMTP配置（如果使用SMTP提供商）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# 社交登录配置
# 微信
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 微博
WEIBO_APP_KEY=your-weibo-app-key
WEIBO_APP_SECRET=your-weibo-app-secret

# 小红书
XIAOHONGSHU_CLIENT_ID=your-xiaohongshu-client-id
XIAOHONGSHU_CLIENT_SECRET=your-xiaohongshu-client-secret
